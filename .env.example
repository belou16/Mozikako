# MOZIKAKO CONFIG
# Copy this file to .env and fill in your provider credentials.

# Frontend
VITE_API_BASE_URL=http://localhost:3001

# Backend
API_PORT=3001
WEB_ORIGIN=http://localhost:5173

# Spotify OAuth
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:3001/api/v1/auth/spotify/callback

# Deezer OAuth
DEEZER_APP_ID=your_deezer_app_id
DEEZER_APP_SECRET=your_deezer_app_secret
DEEZER_REDIRECT_URI=http://localhost:3001/api/v1/auth/deezer/callback

# YouTube API
YOUTUBE_API_KEY=your_youtube_api_key

# Apple Music
APPLE_MUSIC_KEY_ID=your_apple_key_id
APPLE_MUSIC_TEAM_ID=your_apple_team_id
APPLE_MUSIC_PRIVATE_KEY=your_apple_private_key
