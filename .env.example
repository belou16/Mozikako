# MOZIKAKO — API KEYS CONFIGURATION
# Remplacez les valeurs ci-dessous par vos propres identifiants

# SPOTIFY (https://developer.spotify.com/dashboard)
VITE_SPOTIFY_CLIENT_ID=votre_client_id_ici
VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173

# APPLE MUSIC (Nécessite Apple Developer Program)
VITE_APPLE_MUSIC_DEV_TOKEN=votre_token_apple_ici

# DEEZER (https://developers.deezer.com/myapps)
VITE_DEEZER_APP_ID=votre_app_id_deezer_ici
VITE_DEEZER_REDIRECT_URI=http://localhost:5173

# YOUTUBE (https://console.cloud.google.com/)
VITE_YOUTUBE_API_KEY=votre_cle_api_youtube_ici
